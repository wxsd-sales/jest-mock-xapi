# RoomOS hardware parity devices. The script tries WSS first, then SSH.
ROOMOS_PARITY_USERNAME=admin
ROOMOS_PARITY_PASSWORD=password
ROOMOS_PARITY_ADDRESSES='["192.0.2.10","192.0.2.11"]'

# Legacy ROOMOS_PARITY_DEVICES and ROOMOS_PARITY_DEVICE_1_* formats are still
# supported for existing local files, but new setups should use the fields above.

# Optional: command probes send Message.Send payloads, save/remove a hidden UI
# extension panel, and display a 1-second alert on each device.
ROOMOS_PARITY_INCLUDE_COMMAND=true

# Optional: disabled by default because it writes to device configuration, even
# though it writes the current SystemUnit/Name value back to the same path.
ROOMOS_PARITY_INCLUDE_CONFIG_SET=false

# Optional: update the generated README hardware validation table after a
# successful parity run.
ROOMOS_PARITY_UPDATE_README=true

# Optional connection/test timeouts in milliseconds.
ROOMOS_PARITY_CONNECT_TIMEOUT_MS=20000
ROOMOS_PARITY_PROBE_TIMEOUT_MS=20000
ROOMOS_PARITY_TEST_TIMEOUT_MS=120000
